{% schema %}
{
  "name": "Store Location Card",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store Name"
    },
    {
      "type": "text",
      "id": "store_address",
      "label": "Store Address"
    },
    {
      "type": "text",
      "id": "store_hours",
      "label": "Opening Hours"
    },
    {
      "type": "url",
      "id": "store_location",
      "label": "Google Maps Link"
    },
    {
      "type": "url",
      "id": "store_call",
      "label": "Call Link"
    },
    {
      "type": "url",
      "id": "store_products_link",
      "label": "View Products Button Link"
    }
  ],
  "presets": [
    {
      "name": "Store Location Card"
    }
  ]
}
{% endschema %}
<div class="store-card">
  <div class="wrapper">
    <!-- Video Section -->
    <div class="video-container">
      <video
        class="store-media"
        autoplay
        muted
        loop
        playsinline
        poster="{{ section.settings.video_poster | default: 'https://customer-bi7a32qcgc6eo9sl.cloudflarestream.com/b3d2d46303d23417f526387ded423c0e/thumbnails/thumbnail.jpg?time=0s' }}"
        style="object-fit: cover; object-position: center;">
        <source src="{{ section.settings.video_url | default: 'https://cdn.shopify.com/videos/c/o/v/85701b321ab540159b6e09b90bfd00f0.mp4' }}" type="video/mp4">
        Your browser does not support the video tag.
      </video>
    </div>

    <!-- Store Information Section -->
    <div class="store-info">
      <h2>{{ section.settings.store_name }}</h2>
      <p>{{ section.settings.store_address }}</p>
      <p>{{ section.settings.store_hours }}</p>

      <!-- Store Actions (Maps and Call) -->
      <div class="store-actions">
        {% if section.settings.store_location %}
          <a href="{{ section.settings.store_location }}" target="_blank">
            <img height="20" width="20" src="https://cdn.shopify.com/s/files/1/0731/7818/5984/files/svgviewer-output_1.svg?v=1738593172" alt="Google Maps Icon" />
          </a>
        {% endif %}
        {% if section.settings.store_call %}
          <a href="tel:{{ section.settings.store_call }}">
            <img height="20" width="20" src="https://cdn.shopify.com/s/files/1/0731/7818/5984/files/svgviewer-output_2.svg?v=1738593172" alt="Call Icon" />
          </a>
        {% endif %}
      </div>

      <!-- View Products Button -->
      {% if section.settings.store_products_link %}
        <div class="view-products">
          <a href="{{ section.settings.store_products_link }}">VIEW IN-STORE PRODUCTS</a>
        </div>
      {% endif %}
    </div>
  </div>
</div>
<style>
  .store-card {
    background: #fff;
    padding: 0 10px;
    margin: 4rem auto;
    max-width: 1200px; /* Adjust as needed */
  }

  .wrapper {
    display: flex;
    align-items: flex-end;
    gap: 2rem;
  }

  .video-container {
    position: relative;
    width: 100%;
    height: 450px; /* Adjust to fit the screen */
    overflow: hidden;
  }

  .store-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .store-info {
    width: 50%;
  }

  .store-info h2 {
    font-size: 22px;
    font-weight: bold;
    line-height: 2rem;
    margin-bottom: 1rem;
  }

  .store-info p {
    margin: 5px 0;
    color: #000;
  }

  .store-actions {
    display: flex;
    gap: 10px;
    margin: 20px 0;
  }

  .store-actions a {
    font-size: 18px;
    text-decoration: none;
    color: #000;
    border: 1px solid #000;
    padding: 0.5rem;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-products {
    width: 100%;
    background: #792c1c;
    border: 1px solid #792c1c;
    padding: 1rem;
    color: #fff;
    text-align: center;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .view-products:hover {
    background: #fff;
    color: #000;
    border: 1px solid #792c1c;
  }

  @media (max-width: 768px) {
    .wrapper {
      flex-direction: column;
    }

    .store-info,
    .video-container {
      width: 100%;
    }

    .video-container {
      height: 300px; /* Adjust for mobile */
    }
  }
</style>